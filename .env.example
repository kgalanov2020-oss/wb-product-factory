APP_NAME=WB Optimization API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Server-side credentials. Never expose the service-role key to a browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_MPSTATS_TABLE=mpstats_collections

MPSTATS_BASE_URL=https://mpstats.io
MPSTATS_LOGIN_URL=https://mpstats.io/login
MPSTATS_HEADLESS=true
MPSTATS_TIMEOUT_MS=30000
MPSTATS_STORAGE_STATE_PATH=data/mpstats-state.json

# MPStats credentials and CSS selectors must be supplied for the current UI.
MPSTATS_EMAIL=your-login@example.com
MPSTATS_PASSWORD=your-password
MPSTATS_SEARCH_SELECTOR=
