APP_NAME=WB Optimization API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Server-side credentials. Never expose the service-role key to a browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_MPSTATS_TABLE=mpstats_collections
SUPABASE_PRODUCT_CONTENT_JOBS_TABLE=product_content_jobs
SUPABASE_PRODUCT_CONTENT_ACTIONS_TABLE=product_content_actions
SUPABASE_SUPPLIER_PRODUCTS_TABLE=supplier_products
SUPABASE_PRODUCT_ANALYSES_TABLE=product_analyses
SUPABASE_WB_CARD_MAPPINGS_TABLE=wb_card_mappings
SUPABASE_WB_STOCK_SNAPSHOTS_TABLE=wb_stock_snapshots

MPSTATS_BASE_URL=https://mpstats.io
MPSTATS_LOGIN_URL=https://mpstats.io/login
MPSTATS_SEARCH_URL=https://mpstats.io/wb/search
MPSTATS_HEADLESS=true
MPSTATS_TIMEOUT_MS=30000
MPSTATS_STORAGE_STATE_PATH=data/mpstats-state.json

# MPStats credentials and CSS selectors must be supplied for the current UI.
MPSTATS_EMAIL=your-login@example.com
MPSTATS_PASSWORD=your-password
MPSTATS_TOKEN=your-mpstats-api-token
MPSTATS_API_TOKEN=your-mpstats-api-token

AIDENTIKA_BASE_URL=https://api.aidentika.com/api/v1/public
AIDENTIKA_API_KEY=your-aidentika-api-key

OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
